# Configuration Frontend FiscaSync
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=FiscaSync
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Atlas Studio « Proph3t core » (cœur IA mutualisé — projet vgtmljfayiysuvrcmunt)
# ⚠️ Pointe sur le CORE, PAS le Supabase de cette app. Ne JAMAIS committer la
# vraie clé : renseignez-la dans .env / .env.local (gitignorés) ou un secret CI.
# Optionnel : sans ces variables, l'app reste 100% fonctionnelle (les chemins
# Excel / saisie manuelle et l'assistant local Proph3t ne sont pas impactés).
VITE_ATLAS_SUPABASE_URL=https://vgtmljfayiysuvrcmunt.supabase.co
VITE_ATLAS_SUPABASE_ANON_KEY=your-atlas-core-anon-key-here

# Sentry (optional - error monitoring)
VITE_SENTRY_DSN=

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_BUSINESS_MONTHLY=price_...
VITE_STRIPE_PRICE_BUSINESS_YEARLY=price_...
VITE_STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
VITE_STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# CinetPay (Mobile Money — OHADA zone)
VITE_CINETPAY_API_KEY=
VITE_CINETPAY_SITE_ID=
